<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <title>A/B Test Dashboard | RAKUDA AI SOLUTION</title>
  <meta http-equiv="refresh" content="30">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --primary: #1E3A5F;
      --primary-dark: #152D4A;
      --primary-light: #E0E7FF;
      --text: #1E293B;
      --text-sub: #64748B;
      --text-muted: #94A3B8;
      --bg: #F8FAFC;
      --surface: #FFFFFF;
      --border: #E2E8F0;
      --success: #059669;
      --warning: #D97706;
      --danger: #DC2626;
      --sidebar-bg: #0F172A;
      --sidebar-text: #CBD5E1;
      --sidebar-active: #1E3A5F;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Hiragino Sans', 'Hiragino Kaku Gothic ProN', Meiryo, sans-serif;
      color: var(--text);
      background: var(--bg);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    /* ── Layout ───────────────────────────────────────── */
    .admin-layout {
      display: flex;
      min-height: 100vh;
    }

    /* ── Sidebar ──────────────────────────────────────── */
    .sidebar {
      width: 240px;
      background: var(--sidebar-bg);
      padding: 24px 0;
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
    }
    .sidebar-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 0 24px 24px;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      margin-bottom: 24px;
    }
    .sidebar-logo svg path { stroke: #FFF; }
    .sidebar-logo span {
      font-size: 14px;
      font-weight: 300;
      letter-spacing: 0.12em;
      color: #FFF;
    }
    .sidebar-nav {
      list-style: none;
      padding: 0 12px;
    }
    .sidebar-nav li a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 12px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 500;
      color: var(--sidebar-text);
      text-decoration: none;
      transition: all 0.15s;
    }
    .sidebar-nav li a:hover {
      background: rgba(255,255,255,0.06);
      color: #FFF;
    }
    .sidebar-nav li a.active {
      background: var(--sidebar-active);
      color: #FFF;
    }
    .sidebar-nav li a svg {
      width: 18px;
      height: 18px;
      opacity: 0.7;
    }
    .sidebar-footer {
      margin-top: auto;
      padding: 16px 24px;
      border-top: 1px solid rgba(255,255,255,0.08);
    }
    .sidebar-footer a {
      font-size: 12px;
      color: var(--sidebar-text);
      text-decoration: none;
      opacity: 0.6;
    }
    .sidebar-footer a:hover { opacity: 1; }

    /* ── Main Content ─────────────────────────────────── */
    .admin-main {
      flex: 1;
      padding: 32px 40px;
      overflow-x: auto;
    }

    /* ── Header ───────────────────────────────────────── */
    .admin-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 32px;
    }
    .admin-header h1 {
      font-size: 24px;
      font-weight: 800;
      letter-spacing: -0.02em;
    }
    .admin-header-meta {
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .admin-refresh-badge {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      color: var(--text-muted);
    }
    .admin-refresh-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--success);
      animation: blink 2s infinite;
    }
    @keyframes blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.3; }
    }

    /* ── Summary Cards ────────────────────────────────── */
    .summary-cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-bottom: 32px;
    }
    .summary-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 24px;
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .summary-card-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 22px;
      flex-shrink: 0;
    }
    .summary-card-icon.pv { background: #EFF6FF; }
    .summary-card-icon.leads { background: #ECFDF5; }
    .summary-card-icon.bookings { background: #FEF3C7; }
    .summary-card-value {
      font-size: 28px;
      font-weight: 800;
      color: var(--text);
      letter-spacing: -0.02em;
      line-height: 1.2;
    }
    .summary-card-label {
      font-size: 12px;
      color: var(--text-sub);
      font-weight: 500;
    }

    /* ── Section ──────────────────────────────────────── */
    .admin-section {
      margin-bottom: 32px;
    }
    .admin-section-title {
      font-size: 16px;
      font-weight: 700;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .admin-section-title::before {
      content: '';
      width: 3px;
      height: 18px;
      border-radius: 2px;
      background: var(--primary);
    }

    /* ── Tables ───────────────────────────────────────── */
    .table-wrap {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
    }
    .admin-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
    }
    .admin-table thead th {
      padding: 12px 16px;
      text-align: left;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--text-muted);
      background: var(--bg);
      border-bottom: 1px solid var(--border);
    }
    .admin-table tbody td {
      padding: 12px 16px;
      border-bottom: 1px solid var(--border);
      color: var(--text);
      vertical-align: middle;
    }
    .admin-table tbody tr:last-child td {
      border-bottom: none;
    }
    .admin-table tbody tr:hover {
      background: rgba(241,245,249,0.5);
    }

    /* CVR badges */
    .cvr-badge {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 100px;
      font-size: 12px;
      font-weight: 700;
    }
    .cvr-green {
      background: #ECFDF5;
      color: #059669;
    }
    .cvr-yellow {
      background: #FEF3C7;
      color: #D97706;
    }
    .cvr-red {
      background: #FEF2F2;
      color: #DC2626;
    }

    /* Variant badge */
    .variant-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 28px;
      border-radius: 6px;
      font-size: 12px;
      font-weight: 700;
      color: #FFF;
      background: var(--primary);
      text-transform: uppercase;
    }

    /* Event type tag */
    .event-tag {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 11px;
      font-weight: 600;
      background: var(--bg);
      color: var(--text-sub);
      border: 1px solid var(--border);
    }

    /* Source LP tag */
    .source-tag {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 11px;
      font-weight: 600;
      background: var(--primary-light);
      color: var(--primary);
    }

    /* Timestamp */
    .ts {
      font-size: 12px;
      color: var(--text-muted);
      white-space: nowrap;
    }

    /* ── Responsive ───────────────────────────────────── */
    @media (max-width: 1024px) {
      .sidebar { display: none; }
      .admin-main { padding: 24px; }
      .summary-cards { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
<div class="admin-layout">

  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="20" height="20">
        <path d="M10,75 C10,75 22,25 38,25 C52,25 44,65 56,65 C68,65 60,20 74,20 C90,20 100,75 100,75" stroke="#FFF" stroke-width="7" fill="none" stroke-linecap="round"/>
      </svg>
      <span>RAKUDA AI</span>
    </div>
    <ul class="sidebar-nav">
      <li>
        <a href="/admin" class="active">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          Dashboard
        </a>
      </li>
      <li>
        <a href="/">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          LP Preview
        </a>
      </li>
      <li>
        <a href="/tools/diagnostic">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          Diagnostic
        </a>
      </li>
      <li>
        <a href="/tools/roi-calculator">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          ROI Calculator
        </a>
      </li>
    </ul>
    <div class="sidebar-footer">
      <a href="/">Back to Site</a>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="admin-main">
    <!-- Header -->
    <div class="admin-header">
      <h1>A/B Test Dashboard</h1>
      <div class="admin-header-meta">
        <div class="admin-refresh-badge">
          <span class="admin-refresh-dot"></span>
          Auto-refresh: 30s
        </div>
      </div>
    </div>

    <!-- Summary Cards -->
    <div class="summary-cards">
      <div class="summary-card">
        <div class="summary-card-icon pv">&#128202;</div>
        <div>
          <div class="summary-card-value">
            <%= variantStats.reduce(function(s, v) { return s + v.views; }, 0).toLocaleString() %>
          </div>
          <div class="summary-card-label">Total Page Views</div>
        </div>
      </div>
      <div class="summary-card">
        <div class="summary-card-icon leads">&#128101;</div>
        <div>
          <div class="summary-card-value"><%= totalLeads.toLocaleString() %></div>
          <div class="summary-card-label">Total Leads</div>
        </div>
      </div>
      <div class="summary-card">
        <div class="summary-card-icon bookings">&#128197;</div>
        <div>
          <div class="summary-card-value"><%= totalBookings.toLocaleString() %></div>
          <div class="summary-card-label">Total Bookings</div>
        </div>
      </div>
    </div>

    <!-- A/B Test Results -->
    <div class="admin-section">
      <h2 class="admin-section-title">A/B Test Results</h2>
      <div class="table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Variant</th>
              <th>Page Views</th>
              <th>Conversions</th>
              <th>CVR (%)</th>
            </tr>
          </thead>
          <tbody>
            <% variantStats.forEach(function(v) { %>
            <tr>
              <td><span class="variant-badge"><%= v.variant.toUpperCase() %></span></td>
              <td><%= v.views.toLocaleString() %></td>
              <td><%= v.conversions.toLocaleString() %></td>
              <td>
                <% var cvr = parseFloat(v.cvr); %>
                <span class="cvr-badge <%= cvr > 5 ? 'cvr-green' : cvr > 2 ? 'cvr-yellow' : 'cvr-red' %>">
                  <%= v.cvr %>%
                </span>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Conversion Breakdown -->
    <div class="admin-section">
      <h2 class="admin-section-title">Conversion Breakdown</h2>
      <div class="table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Variant</th>
              <th>Event Type</th>
              <th>Count</th>
            </tr>
          </thead>
          <tbody>
            <% variantStats.forEach(function(v) { %>
              <% if (v.breakdown && v.breakdown.length > 0) { %>
                <% v.breakdown.forEach(function(b, i) { %>
                <tr>
                  <% if (i === 0) { %>
                  <td rowspan="<%= v.breakdown.length %>"><span class="variant-badge"><%= v.variant.toUpperCase() %></span></td>
                  <% } %>
                  <td><span class="event-tag"><%= b.event_type %></span></td>
                  <td><%= b.conversions %></td>
                </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td><span class="variant-badge"><%= v.variant.toUpperCase() %></span></td>
                  <td colspan="2" style="color:var(--text-muted);font-style:italic;">No conversions yet</td>
                </tr>
              <% } %>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Recent Leads -->
    <div class="admin-section">
      <h2 class="admin-section-title">Recent Leads</h2>
      <div class="table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Company</th>
              <th>Name</th>
              <th>Email</th>
              <th>Source LP</th>
              <th>Created</th>
            </tr>
          </thead>
          <tbody>
            <% if (recentLeads && recentLeads.length > 0) { %>
              <% recentLeads.forEach(function(lead) { %>
              <tr>
                <td><%= lead.id %></td>
                <td><%= lead.company || '-' %></td>
                <td><%= lead.name || '-' %></td>
                <td><%= lead.email %></td>
                <td><% if (lead.source_lp) { %><span class="source-tag"><%= lead.source_lp %></span><% } else { %>-<% } %></td>
                <td><span class="ts"><%= lead.created_at %></span></td>
              </tr>
              <% }); %>
            <% } else { %>
              <tr>
                <td colspan="6" style="text-align:center;color:var(--text-muted);padding:24px;">No leads yet</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Recent Bookings -->
    <div class="admin-section">
      <h2 class="admin-section-title">Recent Bookings</h2>
      <div class="table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Name</th>
              <th>Email</th>
              <th>Date</th>
              <th>Time Slot</th>
              <th>Source LP</th>
            </tr>
          </thead>
          <tbody>
            <% if (recentBookings && recentBookings.length > 0) { %>
              <% recentBookings.forEach(function(booking) { %>
              <tr>
                <td><%= booking.id %></td>
                <td><%= booking.name || '-' %></td>
                <td><%= booking.email %></td>
                <td><%= booking.date %></td>
                <td><%= booking.time_slot %></td>
                <td><% if (booking.source_lp) { %><span class="source-tag"><%= booking.source_lp %></span><% } else { %>-<% } %></td>
              </tr>
              <% }); %>
            <% } else { %>
              <tr>
                <td colspan="6" style="text-align:center;color:var(--text-muted);padding:24px;">No bookings yet</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

  </main>
</div>
</body>
</html>
